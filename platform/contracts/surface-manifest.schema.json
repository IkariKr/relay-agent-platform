{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-delegate.local/schemas/surface-manifest.schema.json",
  "title": "Codex Delegate Surface Manifest",
  "type": "object",
  "required": [
    "id",
    "package_name",
    "display_name",
    "description",
    "short_description",
    "default_prompt",
    "mode",
    "package_root",
    "doc_entry",
    "notes_backend"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "package_name": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "short_description": {
      "type": "string",
      "minLength": 1
    },
    "default_prompt": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "single-backend",
        "router"
      ]
    },
    "default_backend": {
      "type": "string"
    },
    "allowed_backends": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "public_scripts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "public_assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source",
          "target"
        ],
        "properties": {
          "source": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    },
    "package_root": {
      "type": "string",
      "minLength": 1
    },
    "doc_entry": {
      "type": "string",
      "minLength": 1
    },
    "notes_backend": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    }
  },
  "additionalProperties": true
}
